# Required for production scan
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60

# Scan behavior
SCAN_INTERVAL_MINUTES=30
RUN_DURING_MARKET_HOURS_ONLY=true
STRICT_NEWS_REQUIRED=true

# News source toggles
ENABLE_JIN10=false
ENABLE_WIND=false
ENABLE_BAIDU_HOT=true
ENABLE_GOOGLE_TRENDS=true
ENABLE_OFFICIAL_MEDIA=true
JIN10_MODE=disabled
JIN10_API_URL=
JIN10_API_KEY=
WIND_MODE=disabled
WIND_CSV_PATH=
